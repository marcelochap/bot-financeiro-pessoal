# Bot Financeiro Doméstico — variáveis de ambiente
# Copie este arquivo para .env e preencha. NUNCA commite o .env.

# ─── n8n ────────────────────────────────────────────────────────────
# Versão da imagem. DEV pode usar "latest"; em PRODUÇÃO pinne uma versão
# estável (ex.: 1.70.0) — veja a tag atual em https://hub.docker.com/r/n8nio/n8n/tags
N8N_VERSION=latest
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
# Chave de criptografia das credenciais do n8n. Gere com:
#   powershell: -join ((48..57)+(97..122) | Get-Random -Count 32 | % {[char]$_})
# Guarde com segurança — perder a chave = perder as credenciais salvas.
N8N_ENCRYPTION_KEY=

# Senha para acessar o dashboard de controle financeiro
DASHBOARD_PASSWORD=

# URL da PÁGINA web do dashboard — é o que o comando /dashboard envia no Telegram.
# Aponte para a página servida pelo build estático (rota /dashboard), NÃO para o
# webhook de dados (/webhook/dashboard-data, que é a API JSON consumida pelo React).
# Ex. produção: https://bot.seudominio.com/dashboard
DASHBOARD_URL=

# URL pública dos webhooks. Local: http://localhost:5678/
# Com ngrok: https://<NGROK_DOMAIN>/
WEBHOOK_URL=http://localhost:5678/

TZ=America/Sao_Paulo

# ─── Telegram ───────────────────────────────────────────────────────
# Token do bot (via @BotFather)
TELEGRAM_BOT_TOKEN=
# Chat ID do Marcelo (via @userinfobot)
TELEGRAM_CHAT_ID=

# ─── Gemini (extração de PDF + categorização de desconhecidos) ─────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-preview

# ─── C6 Bank ────────────────────────────────────────────────────────
# Senha dos ZIPs de extrato/fatura do C6 (pessoal — nunca hardcoded)
C6_ZIP_PASSWORD=

# ─── Google Sheets ──────────────────────────────────────────────────
# ID da planilha (trecho entre /d/ e /edit na URL)
GOOGLE_SHEETS_ID=

# ─── ngrok (perfil "tunnel", apenas DEV) ────────────────────────────
NGROK_AUTHTOKEN=
# Domínio estático gratuito do ngrok, ex.: meu-bot.ngrok-free.app
NGROK_DOMAIN=

# ─── PRODUÇÃO (VPS Hostinger — docker-compose.prod.yml) ──────────────
# Domínio real apontado para o IP da VPS (registro A). Ex.: bot.seudominio.com
DOMAIN=
# E-mail para o certificado Let's Encrypt (avisos de expiração)
ACME_EMAIL=
# Em produção, defina também:
#   - WEBHOOK_URL=https://${DOMAIN}/   (o compose.prod já monta isso)
#   - TELEGRAM_WEBHOOK_SECRET=<aleatório forte>   (obrigatório em prod)
#   - N8N_VERSION pinado (não "latest")
