# Bot Financeiro da Harumi (Notion) — variáveis de ambiente
# Copie este arquivo para .env.harumi e preencha. NUNCA commite o .env.harumi.
# Instância separada da do Marcelo: n8n próprio, bot do Telegram próprio, Notion próprio.

# ─── n8n ────────────────────────────────────────────────────────────
N8N_VERSION=latest
N8N_PORT=5679
N8N_HOST=localhost
N8N_PROTOCOL=http
# Chave de criptografia PRÓPRIA — nunca reaproveitar a do Marcelo.
N8N_ENCRYPTION_KEY=

WEBHOOK_URL=http://localhost:5679/
TZ=America/Sao_Paulo

# ─── Telegram (bot da Harumi — @BotFather, separado do bot do Marcelo) ──────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Gemini (Fase B — categorização de desconhecidos) ───────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-preview

# ─── C6 Bank (Harumi também usa C6) ──────────────────────────────────────────
C6_ZIP_PASSWORD=

# ─── Notion ─────────────────────────────────────────────────────────────────
# Token da integração interna (notion.so/my-integrations). Em DEV, usar a
# integração criada no workspace do Marcelo; na Fase F (handoff), trocar pelo
# token de uma integração criada no workspace da própria Harumi.
NOTION_TOKEN=
NOTION_VERSION=2022-06-28

# IDs das databases (Fase A). Pegue cada ID na URL da database no Notion
# (trecho de 32 caracteres antes do "?v=").
NOTION_DB_LANCAMENTOS=
NOTION_DB_DICIONARIO=
NOTION_DB_CATEGORIAS=
NOTION_DB_CONFIG=
NOTION_DB_LOG=
NOTION_DB_METAS=
NOTION_DB_CONTAS_FIXAS=
NOTION_DB_DASHBOARD_MENSAL=
NOTION_DB_FATURA_ABERTA=
NOTION_DB_PARCELAS=

# ─── PRODUÇÃO (Fase F — VPS compartilhada com o bot do Marcelo) ─────────────
# Subdomínio próprio (ex.: harumi.minhaautomacao.cloud), registro A apontado p/ VPS.
DOMAIN=
ACME_EMAIL=
# Em produção, defina também TELEGRAM_WEBHOOK_SECRET=<aleatório forte> e pin N8N_VERSION.
